PROBLEM 33
Digit Cancelling Fractions

The fraction 49/98 is a curious fraction, as an inexperienced mathematician in attemtping
to simplify it may incorrectly believe that 49/98 = 4/8 which is correct by cancelling the 9s

we shall consider the fractions like 30/50 = 3/5 to be trivial examples

there are eactly 4 nontrivial examples of this type of fraction
less than one in value and containing two digits in the numerator and denominator

if the product of these four fracions is given in its lowest common terms,
find the value of the denominator

answer:

ok let me understand the question
it wants me to find the product of the four fractions in lowest common terms
as a denomiator

49/98 -> slash 9 and get 4/8
30/50 -> slash 0 and get 3/5

so ax/bx where when you slash the x you just get a/b
now the question says there are four of these exist
and for the range it says ax/bx < 1 where the range is two digit in num and denominator
so thats 10 - 99

it also seems if both denum and num has a factor of 10 they always digit cancel? not sure
so 10/20 -> 1/2

so this is math focused problem
approach

; find what exactly those 4 fractions mentioned
; sum the products of their denominators

|#

; a fraction is a pair of number
; cons numerator denominator
; (cons 10 20)

; given a fraction, simplifies it by common factor
; where denom is nonzero
; number number -> fraction
(define (simplify-frac num denom)
  ; find common factor
  ; divide both num and denom by common factor, return the value as fracion
  (let ((d (gcd num denom)))
    (cons (/ num d) (/ denom d) )
    )
  )
(simplify-frac 4 12) ; '(1 . 3)

; given two fractions where denom is nonzero, checks if they are equal
(define (is-fraction-equal? frac1 frac2)
  (let ((n1 (car frac1))
        (d1 (cdr frac1))
        (n2 (car frac2))
        (d2 (cdr frac2)))
    (and (= n1 n2) (= d1 d2) )
    )
  )
(display 'is-fraction-equal?)(newline)
(is-fraction-equal? (cons 1 5) (cons 1 5)); compares 1/5 vs 1/5; returns true
(is-fraction-equal? (cons 1 2) (cons 1 5)); compares 1/2 vs 1/5; returns false

; given two fractions where denom is nonzero, checks if they are equal
(define (mult-frac frac1 frac2)
  (let ((n1 (car frac1))
        (d1 (cdr frac1))
        (n2 (car frac2))
        (d2 (cdr frac2)))
    (cons (* n1 n2) (* d1 d2) )
    )
  )

; given a two digit num and denum, checks if its self canceling.
; eg 49/98 -> 4/8 -> correct
; finds shared digit, cancel it, get reduced fraction, compare to original
; tens and units place
(define (is-digit-cancelling? num denom)
  ; if there is a shared digit in num and denum, it's cancelable
  ; else its not cancelable
  ; possible scenarios
  ; n-tens = d-tens, n-tens = d-unit
  ; n-unit = d-tens, n-unit = d-unit
  
  (let* ((n-tens (quotient num 10))
         (n-unit (remainder num 10))
         (d-tens (quotient denom 10))
         (d-unit (remainder denom 10))
         (has-shared-digit-factor? (or (= n-tens d-tens)
                                       (= n-tens d-unit)
                                       (= n-unit d-tens)
                                       (= n-unit d-unit)))
         (has-trivial-digit? (or (= n-unit 0) (= d-unit 0)))
         (simplified-frac (simplify-frac num denom))
         )

    
    ; given a two digit frac n d where n and d has shared common digit factor
    ; and d is nonzero, returns a fraction with cancalled factors.
    ; number number -> fraction (cons number number)
    (define (cancel-frac n d)
      (cond [(= n-tens d-unit) (cons n-unit d-tens)] ;return n-unit, d-tens
            [(= n-tens d-tens) (cons n-unit d-unit)] ;return n-unit, d-unit
            [(= n-unit d-tens) (cons n-tens d-unit)] ;return n-tens, d-unit
            [(= n-unit d-unit) (cons n-tens d-tens)] ;return n-tens, d-tens
            )
      )

    ; exclude trivial zero digit
    ; compare 
    (if (and has-shared-digit-factor? (not has-trivial-digit? ))
        (let* ((canceled-frac (cancel-frac num denom))
               (simplified-cancelled-frac (simplify-frac (car canceled-frac) (cdr canceled-frac)))
               )
          (equal? simplified-cancelled-frac simplified-frac)
          )
        #f
        )
    )  
  )
(display 'is-digit-cancelling?)(newline)
(is-digit-cancelling? 49 98) ; #t
(is-digit-cancelling? 30 50) ; #f
(is-digit-cancelling? 12 34) ; #f
(is-digit-cancelling? 11 23) ; #f


; search space: numerator < denominator
(define (digit-canceling-fractions)
  ; fix numerator -> foreach numerator increment denominator
  ; if denominator reaches limit, increment numerator
  ; stops when numerator is 1 less then denominator
  (define (helper curr-n curr-d acc-fracs)
    (cond [(= curr-n 98) acc-fracs] ;stop
          [(= curr-d 99) (helper (+ 1 curr-n) (+ 2 curr-n) acc-fracs) ] ;increment n, n < d (d+1)
          [(is-digit-cancelling? curr-n curr-d) (helper curr-n (+ curr-d 1) (cons (cons curr-n curr-d) acc-fracs) )] ;digit canceling, add to acc
          [else (helper curr-n (+ 1 curr-d) acc-fracs)] ; keep searching
          )
    )

  ; improvement: enum-pair -> filter is-digit-canceling -> fold
  (define (enum-pairs a b)
    (cond [(= a 98) '()]
          [(= b 99) (enum-pairs (+ a 1) (+ b 2))]
          [else (cons (cons a b) (enum-pairs a (+ b 1))) ]
          )
    )

 
  ; numerator: 10 - 98, denominator: 11 - 99
  ; mult those together, simplify and extract the denom
  (let* ((result (foldr (λ (frac acc) (mult-frac frac acc)) (cons 1 1) (helper 10 11 '())))
         (result-num (car result))
         (result-denom (cdr result)))
    
    (cdr (simplify-frac result-num result-denom))
    
    )
  )
(digit-canceling-fractions)
