#lang racket

#|
PROBLEM 39
INTEGER RIGHT TRIANGLES

if p is the perimeter of a right angle triangle with integral
lenght sides, {a,b,c}, there are exactly three solutions for p = 120

{20,48,52},{24,45,51},{30,40,50}

for which value of p <= 1000, the number of solutions maximised?

answer:
ok so the question is about right triangles

for area if i remember its something like a^2 + b^2 = c^2
where c is the hypotenuse, a and b is the foot length
for perimeter im not really sure, basically lenght of all 3 sides


p = 120 -> 3 solutions
we wanna find most solutions for p <= 1000

approach
- helper that generates all possible triplet list for each number
- probably another helper for the perimeter thing
- main function that keeps track of highest number of solutions

|#

; pythagorean = a^2 + b^2 = c^2
; number number number -> boolean
(define (is-valid-right-triangle? a b c)
  (= (+ (sqr a) (sqr b)) (sqr c))
  )
(is-valid-right-triangle? 20 48 52)

; a Triplet is a list of 3 numbers
; containing triangular triplet (eg 20, 48, 52)

; void -> number
; p = fixed, a = known, b  and c = derived
#|
Derive c from p and a
Derive b from p, a, and c
Check is-valid-right-triangle?
Count solutions for a given p
Find the p with the most solutions
  ; number number number number listof-triplets
  ; a + b + c = p
  ; b = p - a - c
  ; c = p - a - b
  ; a^2 + b^2 = c^2

  ; example: (a=3, p=20)
  ; 3 + b + c = 20
  ; b + c = 17
  ; b = 17 - c 
  
  ; 3^2 + (17-c)^2 = c^2
  ; 9 + (17-c)(17-c) = c^2
  ; 9 + 289 - 17c - 17c -c^2 = c^2
  ; 298 - 34c - c^2 = c^2
  ; 298 - 34c = 2c^2
  ; 2c^2 + 34c = 298
  ; c^2 + 17c = 149
  ; c^2 + 17c - 149 = 0
  ; x = (-b + sqrt(b^2 - 4ac)) / 2a
  ; x = (-17 + sqrt(17^2 - (4.1.-149))) / 2.1
  ; x = -17 + sqrt(289 + 596 ) / 2
  ; x = -17 + 29.7 / 2
|#

#|
count-solutions p
loops over a and b for a fixed p, returns how many valid triangles exist

find-best p best-p best-count
loops p from 1 to 1000, tracks which p has the highest count
|#



(define (integer-right-triangles)

  ; number -> number
  ; b bound: <= p/2
  ; a bound: <= p/3
  (define (count-solutions p)
    (define (loop a b)
      (cond [(> a (quotient p 3)) 0]
            [(> b (quotient p 2)) (loop (+ a 1) a)]
            [else (let ((c (- p a b)))
                    (if (is-valid-right-triangle? a b c)
                        (+ 1 (loop a (+ b 1)) )
                        (loop a (+ b 1))
                        )
                    )]
            )
      )
    (loop 1 1)
    )

  (define (find-best p best-p best-sol-count)
    (cond [(> p 1000) best-p]
          [else (let ((curr-sol-count (count-solutions p)))
                  ; new best p, update sol count and best p
                  ; else keep searching
                  (if (> curr-sol-count best-sol-count)
                      (find-best (+ p 1) p curr-sol-count)
                      (find-best (+ p 1) best-p best-sol-count)
                      )
                  )]
          )
    )

  (find-best 1 0 0)
  )
(integer-right-triangles)