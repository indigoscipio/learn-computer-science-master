#lang racket

#|
PROBLEM 5: Smallest Multiple

2520 is the smallest number that can be divided by each of the numbers from  to  without any remainder.

What is the smallest positive number that is evenly divisible by all of the numbers from  to ?
|#

#|
; number -> boolean
; V1, just return boolean;
(define (smallest-mult-10 n)
  (define (helper curr-n curr-fact)
    (cond [(zero? curr-n) #t] ;curr-n n is zero, return true
          [(zero? (remainder n curr-fact)) (helper (quotient curr-n curr-fact) (+ curr-fact 1))] ;keep dividing it, increase curr-fact by 1
          [else #f] ;false, number is not divisible
          )
    )
  (helper n 1)
  )
(smallest-mult-10 2520) ;returns true
|#


#|
V2, with LCM recursio
; number -> boolean
; smallest-mult-n:: given a number up to n, returns smallest pos int that is evenly divisible by all from 1 to n
(define (smallest-mult-n n)
  ;; acc holds the lcm carried over
  (define (helper curr-fact acc)
    (cond [(> curr-fact n) acc] ;done, just return the lcm
          [else (helper (+ curr-fact 1) (lcm acc curr-fact) )]
          )
    )
  (helper 1 1)
  )
|#

#|
V3: using foldl + LCM
(define (smallest-mult-n n)
  (foldl (λ (curr-fact acc) (lcm acc curr-fact) ) 1 (range 1 (+ n 1)))
  )
(smallest-mult-n 20)
|#