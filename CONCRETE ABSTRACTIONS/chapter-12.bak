#lang racket

; Chapter 12

; MEMO VER
(define (memoized-walk-count n)
  (let ((table (make-vector n)))
    
    (define  (walk-count n)
      (cond ((= n 0) 1)
            ((= n 1) 1)
            (else (+  (walk-count-subproblem (- n 1))
                      (walk-count-subproblem (- n 2))))))

    (define (walk-count-subproblem n)
      (ensure-in-table! n)
      (vector-ref table n)
      )

    ; store all #fs into table initially
    ; if there is a value change it to nonflase
    (define (ensure-in-table! n)
      (if (vector-ref table n)
          'done
          (store-in-table! n)
          )
      )

    (define (store-in-table! n)
      (vector-set! table n (walk-count n))
      )

    (vector-fill! table #f)
    (walk-count n)
    )
  )
(memoized-walk-count 9)

; DP VER
(define (dp-walk-count n)
  (let ((table (make-vector n)))
    
    (define  (walk-count n)
      (cond ((= n 0) 1)
            ((= n 1) 1)
            (else (+  (walk-count-subproblem (- n 1))
                      (walk-count-subproblem (- n 2))))))

    (define (walk-count-subproblem n)
      (vector-ref table n)
      )

    (define (store-into-table! n)
      (vector-set! table n (walk-count n)))

    (define (store-into-table-from! start)
      ; does store-into-table! for values from start through n-1
      (if (= start n)
          'done
          (begin (store-into-table! start) ;store curr
                 (store-into-table! (+ 1 start)) ;store next one
                 )
          )
      )

    (store-into-table-from! 0) ;cache
    (walk-count n) ;start
    
    )
  )

