;sample vector
(define my-vect (make-vector 10))

; note vector is 0 indexed
(define (my-vector-fill! vect value)
  (let ((vect-len (vector-length vect)))

    (define (helper i)
      (cond [(>= i vect-len) vect]
            [else (begin (vector-set! vect i value)
                         (helper (+ i 1)))
                  ]
            )
      )
    (helper 0)
    
    )  
  )
(my-vector-fill! my-vect #t)
my-vect

