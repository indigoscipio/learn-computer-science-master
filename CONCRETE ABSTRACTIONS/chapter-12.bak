; BOX
(define (make-empty-box)
  (list '() 0 0))
(define box-chocolates car)
(define box-weight cadr)
(define box-desirability caddr)

(define (add-chocolate-to-box choc box)
  (list (cons choc (box-chocolates box))
        (+ (chocolate-weight choc) (box-weight box))
        (+ (chocolate-desirability choc) (box-desirability box))))


