EXERCISE 12.14
Write a dynamic programming version of the chocolate box problem in the previous
section. You’ll find it helpful to first write a procedure that when given a number, n,
returns the last n elements of the list of chocolates.

answer:

|#

; given a number n, reutrns last n element of the list xs
(define (last-n-chocolates n xs)
  (reverse (take (reverse xs) n))
  )
(last-n-chocolates 1 '(1 2 3 4 5 6))


(define (dp-pick-chocolates chocolates weight-limit)
  (let ((table (make-table (+ (length chocolates) 1) (+ (weight-limit) 1) )))

    ; main func
    (define (pick-chocolates chocolates weight-limit)
      (cond [(null? chocolates) (make-empty-box)] ; no more to pick
            [(= weight-limit 0) (make-empty-box)] ;fits perfectly
            [(> (chocolate-weight (car chocolates)) weight-limit) 0] ; too heavy, save to table
            [else (better-box (pick-chocolates-subproblem (cdr chocolates) weight-limit) ;exclude
                              (add-chocolate-to-box (car chocolates) (- weight-limit (chocolate-weight (car chocolates))))
                              )] ;include
            )
      )


    ; subproblem
    (define (pick-chocolates-subproblem chocolates weight-limit)
      (table-ref table (length chocolates) weight-limit)
      )
    

    ; store into table
    (define (store-into-table! chocolates weight-limit)
      (table-set! table (length chocolates) weight-limit (pick-chocolates chocolates weight-limit) )
      )

    ;initialize
    ; outer loop: chocolates list, inner loop: weight limit
    (from-to-do 0 (length chocolates)
                (λ (r) (from-to-do 0 weight-limit
                                   (λ (c) (store-into-table! (last-n-chocolates r chocolates) c) )) ))
    
    )
  )

(define (changes vector1 vector2)
  (let ((n (vector-length vector1))
        (m (vector-length vector2)))
    (define (changes-in-first-and-elements i j)
      (cond ((= i 0) j)
            ((= j 0) i)
            (else (if (equal? (vector-ref vector1 (- i 1)) (vector-ref vector2 (- j 1)))
                      (changes-in-first-and-elements (- i 1) (- j 1))
                      (min (+ 1 (changes-in-first-and-elements
                                 (- i 1) j))
                           (+ 1 (changes-in-first-and-elements
                                 i (- j 1)))
                           (+ 1 (changes-in-first-and-elements
                                 (- i 1) (- j 1))))))))
    (changes-in-first-and-elements n m))
  )

#|
Exercise 12.15

Write a memoized version of changes.
answer:
|#

(define (memoized-changes vector1 vector2)
  (let* ((n (vector-length vector1))
         (m (vector-length vector2))
         (table (make-table (+ n 1) (+ m 1))))
    (define (changes-in-first-and-elements i j)
      (cond ((= i 0) j)
            ((= j 0) i)
            (else (if (equal? (vector-ref vector1 (- i 1)) (vector-ref vector2 (- j 1)))
                      (changes-in-first-and-elements-subproblem (- i 1) (- j 1))
                      (min (+ 1 (changes-in-first-and-elements-subproblem
                                 (- i 1) j))
                           (+ 1 (changes-in-first-and-elements-subproblem
                                 i (- j 1)))
                           (+ 1 (changes-in-first-and-elements-subproblem
                                 (- i 1) (- j 1))))))))

    ;subproblem helper
    (define (changes-in-first-and-elements-subproblem i j)
      (ensure-in-table! i j)
      (table-ref table i j)
      )

    ; store in table
    (define (store-into-table! i j)
      (table-set! table i j (changes-in-first-and-elements i j))
      )

    ; ensure in table
    (define (ensure-in-table! i j)
      (if (table-ref table i j)
          'done
          (store-into-table! i j)
          )
      )

    (table-fill! table #f)    
    (changes-in-first-and-elements n m)
    )
  )


