12.8
Write the procedures table-height and table-width. Each of these should take
a table as a parameter and return the number of rows or columns in that table.
|#

(define ( table-ref table row col)
    (vector-ref (vector-ref table row) col))


(define (table-height table)
  (vector-length table)
  )
;(table-height sample-table)

(define (table-width table)
  (vector-length (vector-ref table 0))
  )
;(table-width sample-table)

; PART A
(define (table-fill! table x)
  ; for each row just map every col and change the value
  (let ((row (table-height table))
        (col (table-width table))
        )
    (from-to-do 0 (- row 1) (λ (r) (from-to-do 0 (- col 1) (λ (c) (table-set! table r c x) )) ))
    )
  )
(table-fill! sample-table 'hey)
sample-table

; PART B
(define (display-table table)
  ; dipslay row, for each row dispaly each col (seperated by a few space)
  (let ((row (table-height table))
        (col (table-width table)))
    (from-to-do 0 (- row 1)
                (λ (r) (from-to-do 0 (- col 1)
                                  (λ (c) (begin (display (table-ref table r c))
                                                (display " ")
                                                )))(newline) ))
    )
  )
(display-table sample-table)

