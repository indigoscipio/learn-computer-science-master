#|
12.7 Write the procedure table-set!
|#


(define (from-to-do start stop body)
  (if (> start stop)
      'done
      (begin (body start)
             (from-to-do (+ 1 start) stop body))))

(define (make-table r c)
  (let ((table (make-vector r)))
    (from-to-do 0 (- r 1)
                (lambda (i)
                  (vector-set! table i (make-vector c))))
    table))
(define sample-table (make-table 3 3))


(define (table-set! table row col value)
  (let* ((r (vector-ref table row))
        (c (vector-ref r col))
        )
    (vector-set! r col value)
    )
  )
(table-set! sample-table 0 2 2)
sample-table

