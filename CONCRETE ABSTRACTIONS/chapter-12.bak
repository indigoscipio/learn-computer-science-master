Exercise 12.29

|#

; partition n distinct items into k nonempty teams

; number number -> number
; s(n,k) = s(n-1,k-1) + k.s(n-1,k)
(define (stirling n k)
  ; case: person is alone -> (n-1, k-1)
  ; else person joins -> k(n-1, k)
  (cond [(= n k) 1] ; only 1 way to form a team
        [(> k n) 0] ; more teams than students
        [(= k 1) 1] ; 1 team, only 1 way to form a team, the whole remaining student is that team?
        [else (+ (stirling (- n 1) (- k 1) ) ; person is alone
                 (* k (stirling (- n 1) k)) ; person joins team
                 )]
        )
  )
(stirling 3 2)

; MEMO VERSION
(define (memoized-stirling students teams)
  (let ((table (make-table (+ students 1) (+ teams 1))))

    ; main func
    (define (stirling n k)
      (cond [(= n k) 1] ; only 1 way to form a team
            [(> k n) 0] ; more teams than students
            [(= k 1) 1] ; 1 team, only 1 way to form a team, the whole remaining student is that team?
            [else (+ (stirling-subproblem (- n 1) (- k 1) ) ; person is alone
                     (* k (stirling-subproblem (- n 1) k)) ; person joins team
                     )]
            )
      )
    

    ; subproblem helper
    (define (stirling-subproblem n k)
      (ensure-in-table! n k)
      (table-ref table n k)
      )

    ; ensure in table
    (define (ensure-in-table! n k)
      (if (table-ref table n k)
          'done
          (store-in-table! n k)
          )
      )
    
    ; store in table
    (define (store-in-table! n k)
      (table-set! table n k (stirling n k))
      )
    
    ; initialization
    (table-fill! table #f)
    (stirling students teams)
    )
  )
(memoized-stirling 16 2)

; DP VERSION
(define (dp-stirling students teams)
  (let ((table (make-table (+ students 1) (+ teams 1))))

    ; main func
    (define (stirling n k)
      (cond [(= n k) 1] ; only 1 way to form a team
            [(> k n) 0] ; more teams than students
            [(= k 1) 1] ; 1 team, only 1 way to form a team, the whole remaining student is that team?
            [else (+ (stirling-subproblem (- n 1) (- k 1) ) ; person is alone
                     (* k (stirling-subproblem (- n 1) k)) ; person joins team
                     )]
            ))

    ; subproblem helper
    (define (stirling-subproblem n k)
      (table-ref table n k)
      )
    
    ; store in table
    (define (store-in-table! n k)
      (table-set! table n k (stirling n k))
      )
    
    ; initialization
    ; outer: students loop, inner: teams loop
    (from-to-do 1 students (λ (n)
                             (from-to-do 1 teams (λ (k)
                                                   (store-in-table! n k) ))))

    (table-ref table students teams)  

    )
  )
(dp-stirling 16 2)

