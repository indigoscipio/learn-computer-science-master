; REVIEW PROBLEMS
; Exercise 12.28


; a table is a three element vector
; #(width height flat-vector)

(define sample-flat-table (vector 3 2 (vector 0 1 2 3 4 5))) ; 0 1 2 -> row 1, 3 4 5 -> row2


; SELECTORS
(define (flat-table-width table)
  (vector-ref table 0)
  )
(flat-table-width sample-flat-table) ;3

(define (flat-table-height table)
  (vector-ref table 1)
  )
(flat-table-height sample-flat-table) ;2

(define (flat-table-data table)
  (vector-ref table 2)
  )

(define (flat-table-ref r c table)
  ; extract
  (vector-ref (flat-table-data table) (+ (* (flat-table-width table) r) c) )
  )
(flat-table-ref 1 0 sample-flat-table)

; CONSTRUCTORS
(define (flat-table-set! table r c value)
  (vector-set! (flat-table-data table) (+ (* (flat-table-width table) r) c)  value)
  )
(flat-table-set! sample-flat-table 1 1 'GG)
sample-flat-table

(define (make-flat-table r c)
  (vector c r (make-vector (* r c)))
  )
(make-flat-table 3 5)

