Exercise 4.17

|#

; n = total number to choose from
; k = items to pick
(define (choose n k)
  ; base case: k=0 and k=n
  (cond [(or (zero? k) (equal? k n)) 1]
        [else (let ((pick (choose (- n 1) (- k 1)))
                    (dont-pick (choose (- n 1) k))
                    )
                (+ pick dont-pick)
                ;; select it
                ;; dont select it
                )]
        
        )
  )
(choose 5 5)

