(define make-point cons)
(define x-coord car)
(define y-coord cdr)


; Exercise 9.19
(define (make-square x y side)
  (λ (op) (cond [(equal? op 'center-x ) x]
                [(equal? op 'center-y) y]
                [(equal? op 'area) (sqr side)]
                [else (error "invalid operation" op)]
                ))
  )

(define (make-circle x y r)
  (λ (op) (cond [(equal? op 'center-x ) x]
                [(equal? op 'center-y) y]
                [(equal? op 'area) (* pi (sqr r))]
                [else (error "invalid operation" op)]
                ))
  )

(define c (make-circle 0 0 5))
(define s (make-square 0 0 10))
(define (area shape)
  (shape 'area)
  )
(area c)
(area s)

