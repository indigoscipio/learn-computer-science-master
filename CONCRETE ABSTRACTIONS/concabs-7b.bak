#|
Exercise 29
Extend matches? so that it also checks for the _ wild card. Remember that this is a
wild card for a single word. Also, remember that there can be more than one _ in a
single pattern and that they need not be at the end of the pattern.


Exercise 30
Extend substitutions-in-to-match to account for both of these extensions. It
should return the list of substitutions, one for each wild card.
|#

; SUBSTITUTIONS-IN-TO-MATCH
(define (substitutions-in-to-match pattern query)
  (cond [(null? pattern) '()] ; no ..., no substitution
        [(equal? (car pattern) '...) (list query)]
        [(equal? (car pattern) '_) (cons (car query) (substitutions-in-to-match (cdr pattern) (cdr query)) )] ;substitute
        [else (substitutions-in-to-match (cdr pattern) (cdr query))]
        )
  )
(substitutions-in-to-match '(what _ was made in _)
                            '(what movie was made in 1955))

; MATCHER
(define (matches? pattern question)
  (cond [(null? pattern) (null? question)]
        [(null? question) #f]
        [(list? (car pattern)) (if (member (car question) (car pattern))
                                                        (matches? (cdr pattern) (cdr question))
                                                        #f)]
        [(equal? (car pattern) '...) #t]
        [(equal? (car pattern) '_) (matches? (cdr pattern) (cdr question))] ;check for _ wildcard
        [(equal? (car pattern) (car question)) (matches? (cdr pattern) (cdr question))]
        [else #f]
        )
  )

#|
Exercise 7.33

Filter article
|#

; symbol -> boolean
; given a symbol, checks if its an article
(define (is-article? symbol)
  (or (equal? symbol 'the)
      (equal? symbol 'an)
      (equal? symbol 'a))
  )

(define (same-title? title target)
  (equal? (filter (λ (symbol) (not (is-article? symbol))) title)
          (filter (λ (symbol) (not (is-article? symbol))) target))
  )
(same-title? '(the godfather) '(godfather)) ; => #t
(same-title? '(the godfather) '(amarcord))  ; => #f

