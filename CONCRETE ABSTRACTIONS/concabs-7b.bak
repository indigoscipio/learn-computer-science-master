(define (generate-all-prefix xs)
  (cond [(null? xs) (list '())]
        [else (cons '() (map (lambda (prefix) (cons (car xs) prefix)) (generate-all-prefix (cdr xs)))
                    ) ])
  )
(generate-all-prefix '(boyz in the hood))

