#lang racket

; find elmeent that dominates in a list

; listofx -> x
; assume lst is nonempty
(define (find-majority lst)
  (let ((n (length lst)))
    
    (define (helper xs count curr-item)
      (cond [(null? xs) curr-item ] ; check if count > 0, if so return curr-item
            [(zero? count) (helper (cdr xs) 1 (car xs))]
            [(equal? curr-item (car xs)) (helper (cdr xs) (+ count 1) curr-item)] ;same, add count
            [else (helper (cdr xs) (- count 1) curr-item)] ;different, reduce count
            )
      )
    (helper (cdr lst) 1 (car lst))

    (define (count-occurences item lst)
      (length (filter (λ (x) (equal? x item)) lst))
      )
    
    )  
  )
(find-majority '(a a a a a a d b)) ;should reutrn a